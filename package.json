{
  "name": "affilync-desktop",
  "productName": "Affilync",
  "version": "0.1.0",
  "description": "Affilync desktop app — always-available call-center softphone and brand dashboard",
  "main": "dist/main/index.js",
  "author": "Affilync <info@affilync.com>",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/moneyflowz367/affilync-desktop.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p src/preload/tsconfig.json",
    "start": "npm run build && electron .",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p src/preload/tsconfig.json --noEmit",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "release": "npm run build && electron-builder --publish always"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
